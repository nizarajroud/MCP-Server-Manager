# MCP Server Manager - Environment Variables

# GitHub API (required)
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=nizarajroud/kiro-configs

# Backend
PORT=3001

# Branch & Agent defaults
LOCAL_BRANCH=personal-branch
DEFAULT_AGENT=exp2
LEGACY_MCP_PATH=settings/mcp.json
LOCAL_REPO_PATH=/home/nizar/HomeWspce/kiro-configs

# Delivery / Prod
PROD_DIR=/home/nizar/.mcp-server-manager-prod
PROD_BACKEND_PORT=4001
PROD_FRONTEND_PORT=4000
APP_REPO_URL=https://github.com/nizarajroud/MCP-Server-Manager.git
SERVICE_NAME=mcp-server-manager

# Dev
DEV_BACKEND_PORT=3001
DEV_FRONTEND_PORT=3000

# Frontend (Vite exposes VITE_ prefixed vars to the browser)
VITE_BACKEND_URL=http://localhost:3001
