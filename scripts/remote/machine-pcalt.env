# Machine configuration for MCP remote deployment
# Copy this file and adjust values for each new machine.

# Machine identity
MACHINE_NAME=pcalt
MACHINE_HOST=192.168.2.56

# WSL internal IP (run `hostname -I` inside WSL to find it)
WSL_IP=172.23.117.7

# SSH access (from ENVY to this machine's WSL)
SSH_PORT=2222
SSH_USER=nizar
SSH_KEY=~/.ssh/id_rsa_wsl

# MCP server ports
BASE_PORT=3200
PORT_COUNT=50

# Supergateway config
SUPERGATEWAY_CMD="npx -y supergateway"
LOG_DIR=/tmp

# Remote paths (on the target WSL)
REMOTE_PROJECT_DIR=/home/nizar/workspace/Trainings/MCP-Server-Manager
REMOTE_KIRO_CONFIGS=/home/nizar/HomeWspce/kiro-configs

# ============================================================
# SETUP NOTES
# ============================================================
# 1. Port forwarding (run ONCE on Windows PowerShell as admin):
#    3200..3400 | ForEach-Object { netsh interface portproxy add v4tov4 listenport=$_ listenaddress=0.0.0.0 connectport=$_ connectaddress=172.23.117.7 }
#
# 2. Firewall (run ONCE on Windows PowerShell as admin):
#    New-NetFirewallRule -DisplayName "WSL MCP Servers" -Direction Inbound -Protocol TCP -LocalPort 3200-3400 -Action Allow
#
# 3. Verify:
#    netsh interface portproxy show all
