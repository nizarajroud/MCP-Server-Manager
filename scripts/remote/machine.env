# Machine configuration for MCP remote deployment
# Copy this file and adjust values for each new machine.

# Machine identity
MACHINE_NAME=pcalt
MACHINE_HOST=192.168.2.56

# WSL internal IP (run `hostname -I` inside WSL to find it)
WSL_IP=172.23.117.7

# SSH access (from ENVY to this machine's WSL)
SSH_PORT=2222
SSH_USER=nizar
SSH_KEY=~/.ssh/id_rsa_wsl

# MCP server ports
BASE_PORT=3200
PORT_COUNT=14

# Supergateway config
SUPERGATEWAY_CMD="npx -y supergateway"
LOG_DIR=/tmp
